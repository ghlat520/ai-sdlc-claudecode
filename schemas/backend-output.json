{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "S3 Backend Output",
  "description": "StageOutput schema for Backend Development stage",
  "type": "object",
  "required": ["stage_id", "feature_id", "timestamp", "status", "implementation"],
  "properties": {
    "stage_id": { "const": "S3" },
    "feature_id": { "type": "string", "minLength": 1 },
    "timestamp": { "type": "string", "format": "date-time" },
    "status": { "enum": ["complete", "partial", "failed"] },
    "implementation": {
      "type": "object",
      "required": ["files_changed", "compile_result"],
      "properties": {
        "files_changed": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["path", "change_type", "line_count"],
            "properties": {
              "path": { "type": "string" },
              "change_type": { "enum": ["added", "modified", "deleted"] },
              "line_count": { "type": "integer", "maximum": 800 },
              "description": { "type": "string" }
            }
          }
        },
        "compile_result": {
          "type": "object",
          "required": ["success", "command"],
          "properties": {
            "success": { "type": "boolean" },
            "command": { "type": "string" },
            "warnings": { "type": "integer" },
            "errors": { "type": "integer" },
            "output_snippet": { "type": "string" }
          }
        },
        "api_endpoints_implemented": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["endpoint", "method", "status"],
            "properties": {
              "endpoint": { "type": "string" },
              "method": { "type": "string" },
              "status": { "enum": ["implemented", "stubbed"] }
            }
          }
        },
        "dependencies_added": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["group_id", "artifact_id", "version"],
            "properties": {
              "group_id": { "type": "string" },
              "artifact_id": { "type": "string" },
              "version": { "type": "string" }
            }
          }
        },
        "git_diff_summary": { "type": "string" }
      }
    },
    "metadata": {
      "type": "object",
      "properties": {
        "agent_model": { "type": "string" },
        "tokens_used": { "type": "integer" },
        "duration_seconds": { "type": "number" },
        "retry_count": { "type": "integer" }
      }
    }
  }
}
