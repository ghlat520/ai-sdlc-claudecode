{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "S1 Requirements Output",
  "description": "StageOutput schema for Requirements Analysis stage",
  "type": "object",
  "required": ["stage_id", "feature_id", "timestamp", "status", "prd"],
  "properties": {
    "stage_id": { "const": "S1" },
    "feature_id": { "type": "string", "minLength": 1 },
    "timestamp": { "type": "string", "format": "date-time" },
    "status": { "enum": ["complete", "partial", "failed"] },
    "prd": {
      "type": "object",
      "required": ["title", "summary", "functional_requirements", "non_functional_requirements", "user_stories", "acceptance_criteria"],
      "properties": {
        "title": { "type": "string", "minLength": 1 },
        "summary": { "type": "string", "minLength": 50 },
        "functional_requirements": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["id", "description", "priority"],
            "properties": {
              "id": { "type": "string", "pattern": "^FR-\\d+$" },
              "description": { "type": "string" },
              "priority": { "enum": ["must", "should", "could", "wont"] }
            }
          }
        },
        "non_functional_requirements": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["id", "category", "description", "metric"],
            "properties": {
              "id": { "type": "string", "pattern": "^NFR-\\d+$" },
              "category": { "enum": ["performance", "security", "scalability", "reliability", "usability"] },
              "description": { "type": "string" },
              "metric": { "type": "string" }
            }
          }
        },
        "user_stories": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["id", "as_a", "i_want", "so_that"],
            "properties": {
              "id": { "type": "string", "pattern": "^US-\\d+$" },
              "as_a": { "type": "string" },
              "i_want": { "type": "string" },
              "so_that": { "type": "string" }
            }
          }
        },
        "acceptance_criteria": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["id", "given", "when", "then"],
            "properties": {
              "id": { "type": "string", "pattern": "^AC-\\d+$" },
              "given": { "type": "string" },
              "when": { "type": "string" },
              "then": { "type": "string" }
            }
          }
        },
        "out_of_scope": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "metadata": {
      "type": "object",
      "properties": {
        "agent_model": { "type": "string" },
        "tokens_used": { "type": "integer" },
        "duration_seconds": { "type": "number" },
        "retry_count": { "type": "integer" }
      }
    }
  }
}
