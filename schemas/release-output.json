{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "S10 Release Output",
  "description": "StageOutput schema for Release & Rollout stage",
  "type": "object",
  "required": ["stage_id", "feature_id", "timestamp", "status", "release"],
  "properties": {
    "stage_id": { "const": "S10" },
    "feature_id": { "type": "string", "minLength": 1 },
    "timestamp": { "type": "string", "format": "date-time" },
    "status": { "enum": ["complete", "partial", "failed"] },
    "release": {
      "type": "object",
      "required": ["version", "checklist", "rollback_plan"],
      "properties": {
        "version": { "type": "string" },
        "checklist": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["item", "status"],
            "properties": {
              "item": { "type": "string" },
              "status": { "enum": ["done", "pending", "skipped", "blocked"] },
              "notes": { "type": "string" }
            }
          }
        },
        "rollback_plan": {
          "type": "object",
          "required": ["steps", "estimated_time"],
          "properties": {
            "steps": {
              "type": "array",
              "minItems": 1,
              "items": { "type": "string" }
            },
            "estimated_time": { "type": "string" },
            "trigger_conditions": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        },
        "deployment_strategy": {
          "type": "object",
          "properties": {
            "type": { "enum": ["rolling", "blue-green", "canary", "recreate"] },
            "canary_percent": { "type": "number" },
            "stages": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        },
        "notifications": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["audience", "channel", "message"],
            "properties": {
              "audience": { "type": "string" },
              "channel": { "type": "string" },
              "message": { "type": "string" }
            }
          }
        }
      }
    },
    "metadata": {
      "type": "object",
      "properties": {
        "agent_model": { "type": "string" },
        "tokens_used": { "type": "integer" },
        "duration_seconds": { "type": "number" },
        "retry_count": { "type": "integer" }
      }
    }
  }
}
