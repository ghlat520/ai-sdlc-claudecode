{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "S4 Testing Output",
  "description": "StageOutput schema for Testing stage",
  "type": "object",
  "required": ["stage_id", "feature_id", "timestamp", "status", "testing"],
  "properties": {
    "stage_id": { "const": "S4" },
    "feature_id": { "type": "string", "minLength": 1 },
    "timestamp": { "type": "string", "format": "date-time" },
    "status": { "enum": ["complete", "partial", "failed"] },
    "testing": {
      "type": "object",
      "required": ["test_files", "test_results", "coverage"],
      "properties": {
        "test_files": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["path", "test_type", "test_count"],
            "properties": {
              "path": { "type": "string" },
              "test_type": { "enum": ["unit", "integration", "e2e"] },
              "test_count": { "type": "integer", "minimum": 1 }
            }
          }
        },
        "test_results": {
          "type": "object",
          "required": ["total", "passed", "failed", "skipped"],
          "properties": {
            "total": { "type": "integer" },
            "passed": { "type": "integer" },
            "failed": { "type": "integer" },
            "skipped": { "type": "integer" },
            "duration_seconds": { "type": "number" },
            "command": { "type": "string" },
            "failures": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["test_name", "error"],
                "properties": {
                  "test_name": { "type": "string" },
                  "error": { "type": "string" }
                }
              }
            }
          }
        },
        "coverage": {
          "type": "object",
          "required": ["line_percent"],
          "properties": {
            "line_percent": { "type": "number", "minimum": 0, "maximum": 100 },
            "branch_percent": { "type": "number", "minimum": 0, "maximum": 100 },
            "target_met": { "type": "boolean" }
          }
        },
        "acceptance_criteria_coverage": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["ac_id", "covered_by_test"],
            "properties": {
              "ac_id": { "type": "string" },
              "covered_by_test": { "type": "string" }
            }
          }
        }
      }
    },
    "metadata": {
      "type": "object",
      "properties": {
        "agent_model": { "type": "string" },
        "tokens_used": { "type": "integer" },
        "duration_seconds": { "type": "number" },
        "retry_count": { "type": "integer" }
      }
    }
  }
}
