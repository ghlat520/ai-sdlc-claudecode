{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "S4c E2E Test Output",
  "description": "StageOutput schema for End-to-End Testing stage",
  "type": "object",
  "required": ["stage_id", "feature_id", "timestamp", "status", "testing"],
  "properties": {
    "stage_id": { "const": "S4c" },
    "feature_id": { "type": "string", "minLength": 1 },
    "timestamp": { "type": "string", "format": "date-time" },
    "status": { "enum": ["complete", "partial", "failed"] },
    "testing": {
      "type": "object",
      "required": ["test_results", "journeys"],
      "properties": {
        "test_results": {
          "type": "object",
          "required": ["total", "passed", "failed", "skipped"],
          "properties": {
            "total": { "type": "integer" },
            "passed": { "type": "integer" },
            "failed": { "type": "integer" },
            "skipped": { "type": "integer" }
          }
        },
        "journeys": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["name", "steps", "passed"],
            "properties": {
              "name": { "type": "string" },
              "steps": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["action", "passed"],
                  "properties": {
                    "action": { "type": "string" },
                    "passed": { "type": "boolean" },
                    "screenshot": { "type": "string" },
                    "duration_ms": { "type": "number" }
                  }
                }
              },
              "passed": { "type": "boolean" },
              "duration_ms": { "type": "number" }
            }
          }
        },
        "browser": { "type": "string" },
        "viewport": { "type": "string" }
      }
    },
    "metadata": {
      "type": "object",
      "properties": {
        "agent_model": { "type": "string" },
        "tokens_used": { "type": "integer" },
        "duration_seconds": { "type": "number" },
        "retry_count": { "type": "integer" }
      }
    }
  }
}
