{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "S6 Deployment Output",
  "description": "StageOutput schema for Deployment stage",
  "type": "object",
  "required": ["stage_id", "feature_id", "timestamp", "status", "deployment"],
  "properties": {
    "stage_id": { "const": "S6" },
    "feature_id": { "type": "string", "minLength": 1 },
    "timestamp": { "type": "string", "format": "date-time" },
    "status": { "enum": ["complete", "partial", "failed"] },
    "deployment": {
      "type": "object",
      "required": ["checklist", "rollback_plan", "artifacts"],
      "properties": {
        "checklist": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["step", "description", "verified"],
            "properties": {
              "step": { "type": "integer" },
              "description": { "type": "string" },
              "verified": { "type": "boolean" },
              "command": { "type": "string" }
            }
          }
        },
        "rollback_plan": {
          "type": "object",
          "required": ["steps", "estimated_time"],
          "properties": {
            "steps": {
              "type": "array",
              "minItems": 1,
              "items": { "type": "string" }
            },
            "estimated_time": { "type": "string" },
            "data_migration_reversible": { "type": "boolean" }
          }
        },
        "artifacts": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "path", "type"],
            "properties": {
              "name": { "type": "string" },
              "path": { "type": "string" },
              "type": { "enum": ["jar", "sql", "config", "script"] }
            }
          }
        },
        "monitoring": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["metric", "threshold", "alert_channel"],
            "properties": {
              "metric": { "type": "string" },
              "threshold": { "type": "string" },
              "alert_channel": { "type": "string" }
            }
          }
        },
        "environment_changes": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["key", "description"],
            "properties": {
              "key": { "type": "string" },
              "description": { "type": "string" },
              "sensitive": { "type": "boolean" }
            }
          }
        }
      }
    },
    "metadata": {
      "type": "object",
      "properties": {
        "agent_model": { "type": "string" },
        "tokens_used": { "type": "integer" },
        "duration_seconds": { "type": "number" },
        "retry_count": { "type": "integer" }
      }
    }
  }
}
