{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "S8 Documentation Output",
  "description": "StageOutput schema for Documentation stage",
  "type": "object",
  "required": ["stage_id", "feature_id", "timestamp", "status", "documentation"],
  "properties": {
    "stage_id": { "const": "S8" },
    "feature_id": { "type": "string", "minLength": 1 },
    "timestamp": { "type": "string", "format": "date-time" },
    "status": { "enum": ["complete", "partial", "failed"] },
    "documentation": {
      "type": "object",
      "required": ["api_docs", "user_guide"],
      "properties": {
        "api_docs": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["endpoint", "method", "description"],
            "properties": {
              "endpoint": { "type": "string" },
              "method": { "type": "string" },
              "description": { "type": "string" },
              "request_example": { "type": "object" },
              "response_example": { "type": "object" }
            }
          }
        },
        "user_guide": {
          "type": "object",
          "required": ["sections"],
          "properties": {
            "sections": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "required": ["title", "content"],
                "properties": {
                  "title": { "type": "string" },
                  "content": { "type": "string" }
                }
              }
            }
          }
        },
        "changelog_entry": {
          "type": "object",
          "required": ["version", "changes"],
          "properties": {
            "version": { "type": "string" },
            "changes": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["type", "description"],
                "properties": {
                  "type": { "enum": ["added", "changed", "fixed", "removed", "deprecated"] },
                  "description": { "type": "string" }
                }
              }
            }
          }
        },
        "architecture_diagram": { "type": "string" },
        "runbook": { "type": "string" }
      }
    },
    "metadata": {
      "type": "object",
      "properties": {
        "agent_model": { "type": "string" },
        "tokens_used": { "type": "integer" },
        "duration_seconds": { "type": "number" },
        "retry_count": { "type": "integer" }
      }
    }
  }
}
